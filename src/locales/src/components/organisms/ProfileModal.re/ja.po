#: src/components/organisms/ProfileModal.re.mjs:260
msgid "Complete your profile"
msgstr "プロフィールを完成させる"

#: src/components/organisms/ProfileModal.re.mjs:283
msgid "Display name"
msgstr "表示名"

#: src/components/organisms/ProfileModal.re.mjs:73
msgid "Display name is required"
msgstr "表示名は必須です"

#: src/components/organisms/ProfileModal.re.mjs:300
msgid "Email address"
msgstr "メールアドレス"

#: src/components/organisms/ProfileModal.re.mjs:155
msgid ""
"Email address is unavailable. Please use a different email or login with the "
"email you are trying to use here."
msgstr ""
"このメールアドレスは使用できません。別のメールアドレスを使用するか、ここで使"
"用しようとしているメールアドレスでログインしてください。"

#: src/components/organisms/ProfileModal.re.mjs:232
msgid "Email cannot be changed"
msgstr "メールアドレスは変更できません"

#: src/components/organisms/ProfileModal.re.mjs:76
msgid "Email is required"
msgstr "メールアドレスは必須です"

#: src/components/organisms/ProfileModal.re.mjs:232
msgid "For event updates and notifications"
msgstr "イベントの更新と通知用"

#: src/components/organisms/ProfileModal.re.mjs:315
msgid "Save & Join Event"
msgstr "保存して参加する"

#: src/components/organisms/ProfileModal.re.mjs:207
msgid "This is how others will see you"
msgstr "他の人に表示される名前です"

#: src/components/organisms/ProfileModal.re.mjs:264
msgid "We need a few details before you can join this event"
msgstr "イベント参加に必要な情報を入力してください"
