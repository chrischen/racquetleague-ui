msgid "Claim spot"
msgstr "参加する"

#: src/components/organisms/EventStickyFooter.re.mjs:429
msgid "Claim spot · {0}"
msgstr "スポットを予約 · {0}"

#: src/components/organisms/ProfileModal.re.mjs:335
msgid "Complete your profile"
msgstr "プロフィールを完成させる"

#: src/components/organisms/EventStickyFooter.re.mjs:187
