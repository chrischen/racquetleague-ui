#: src/components/organisms/ProfileModal.re.mjs:375
msgid "Email address"
msgstr "メールアドレス"

#: src/components/organisms/ProfileModal.re.mjs:226
msgid ""
"Email address is unavailable. Please use a different email or login with the "
"email you are trying to use here."
