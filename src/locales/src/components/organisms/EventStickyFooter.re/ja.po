msgid "Leave waitlist"
msgstr "キャンセル待ちを取り消す"

#: src/components/organisms/EventStickyFooter.re.mjs:379
msgid "Leaving..."
msgstr "キャンセル中..."

#: src/components/organisms/EventStickyFooter.re.mjs:169
msgid "Loading..."
msgstr "読み込み中..."

#: src/components/organisms/ProfileModal.re.mjs:401
msgid "Male"
msgstr "男性"

#: src/components/organisms/EventStickyFooter.re.mjs:361
