msgid "Reset (All)"
msgstr "รีเซ็ต (ทั้งหมด)"

msgid "Resets the round to the original matches."
msgstr "รีเซ็ตรอบกลับไปเป็นการแข่งขันเดิม"

msgid "Player Management"
msgstr "การจัดการผู้เล่น"

