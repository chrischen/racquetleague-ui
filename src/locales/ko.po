msgid "Find League Games"
msgstr "리그 게임 찾기"

#: src/components/pages/FindGamesPage.re.mjs:30
msgid "To participate in the league and win prizes, please join the league events."
msgstr "리그에 참가하고 상을 받으려면 리그 이벤트에 참가하세요."

